# Copy this file to .env and fill in your values.

# Email delivery (e.g. SendGrid, Mailgun, or SMTP)
EMAIL_PROVIDER=smtp
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Sender identity
FROM_NAME=Your Name
FROM_EMAIL=you@example.com

# Invoice / accounting
INVOICE_PREFIX=INV
DEFAULT_CURRENCY=USD
DEFAULT_PAYMENT_TERMS_DAYS=14

# Optional integrations
NOTION_API_KEY=
NOTION_DATABASE_ID=
TOGGL_API_TOKEN=
HARVEST_ACCOUNT_ID=
HARVEST_ACCESS_TOKEN=
